<Window x:Class="SortVisualizer.BenchmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sort Benchmark"
        Width="1180"
        Height="760"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="210"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#111827"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Sort Algorithm Benchmark"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"/>
                <TextBlock Text="同じデータを使って、各ソートアルゴリズムの実行時間を比較"
                           Foreground="#D1D5DB"
                           FontSize="14"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Settings -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Data Size"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,8,0"/>

                <TextBox Grid.Column="1"
                         x:Name="DataSizeTextBox"
                         Text="5000"
                         Height="32"
                         VerticalContentAlignment="Center"
                         Margin="0,0,20,0"/>

                <TextBlock Grid.Column="2"
                           Text="Repeat"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,8,0"/>

                <TextBox Grid.Column="3"
                         x:Name="RepeatTextBox"
                         Text="3"
                         Height="32"
                         VerticalContentAlignment="Center"
                         Margin="0,0,20,0"/>

                <Button Grid.Column="5"
                        Content="Generate Data"
                        Width="120"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="GenerateDataButton_Click"/>

                <Button Grid.Column="6"
                        Content="Run All"
                        Width="100"
                        Height="34"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="Bold"
                        Margin="0,0,8,0"
                        Click="RunAllButton_Click"/>

                <Button Grid.Column="7"
                        Content="Clear"
                        Width="80"
                        Height="34"
                        Click="ClearButton_Click"/>
            </Grid>
        </Border>

        <!-- Result + Chart -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <!-- Result Table -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="14"
                    Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Benchmark Results"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <DataGrid Grid.Row="1"
                              x:Name="ResultDataGrid"
                              ItemsSource="{Binding Results}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="36"
                              FontSize="14">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Algorithm"
                                                Binding="{Binding AlgorithmName}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Data Size"
                                                Binding="{Binding DataSize}"
                                                Width="100"/>

                            <DataGridTextColumn Header="Elapsed ms"
                                                Binding="{Binding ElapsedMilliseconds, StringFormat=F4}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="110"/>

                            <DataGridTemplateColumn Header="Action"
                                                    Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Run"
                                                Height="26"
                                                Click="RunSingleButton_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Bar Chart -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Elapsed Time Chart"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <TextBlock Text="長い棒ほど実行時間が長い"
                                   Foreground="#6B7280"
                                   FontSize="13"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Results}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding AlgorithmName}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>

                                        <Grid Grid.Column="1"
                                              Height="24"
                                              VerticalAlignment="Center"
                                              Background="#F3F4F6">
                                            <Border Width="{Binding ChartWidth}"
                                                    HorizontalAlignment="Left"
                                                    Background="#2563EB"
                                                    CornerRadius="4"/>
                                        </Grid>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ElapsedMilliseconds, StringFormat={}{0:F3} ms}"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Actual Data -->
        <Border Grid.Row="3"
                Background="White"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.ColumnSpan="2"
                            Margin="0,0,0,10">
                    <TextBlock Text="Actual Data"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock Text="計測前は元データ、実行後は選択・実行されたアルゴリズムのソート結果を表示します。計測自体は元データのコピーで行います。"
                               Foreground="#6B7280"
                               FontSize="13"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Data Table -->
                <DataGrid Grid.Row="1"
                          Grid.Column="0"
                          ItemsSource="{Binding DataValues}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="28"
                          FontSize="13"
                          Margin="0,0,14,0">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Index"
                                            Binding="{Binding Index}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Value"
                                            Binding="{Binding Value}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Data Preview Text -->
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding DataPreviewText}"
                         FontFamily="Consolas"
                         FontSize="13"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         IsReadOnly="True"
                         Background="#F9FAFB"
                         BorderBrush="#E5E7EB"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4"
                Background="White"
                CornerRadius="12"
                Padding="14">
            <TextBlock x:Name="MessageTextBlock"
                       Text="Generate Data で配列を作ってから、Run All または各行の Run を押してください。"
                       FontSize="14"/>
        </Border>
    </Grid>
</Window>