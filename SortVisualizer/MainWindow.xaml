<Window x:Class="SortVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:SortVisualizer.Models"
        Title="Sort Algorithm Visualizer"
        Width="1180"
        Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#1F2937"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">
            <DockPanel>
                <TextBlock Text="Sort Algorithm Visualizer"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"
                           DockPanel.Dock="Left"/>

                <TextBlock Text="比較・交換・pivot・確定位置を見える化"
                           Foreground="#D1D5DB"
                           FontSize="14"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Main -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="330"/>
            </Grid.ColumnDefinitions>

            <!-- Control Panel -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Control"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Algorithm"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <ComboBox ItemsSource="{Binding Algorithms}"
                              SelectedItem="{Binding SelectedAlgorithm}"
                              Height="34"
                              Margin="0,0,0,16"/>

                    <TextBlock Text="Array Size"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Slider Minimum="5"
                                Maximum="100"
                                Value="{Binding ArraySize}"
                                Width="150"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"/>
                        <TextBlock Text="{Binding ArraySize}"
                                   Width="40"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Speed"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Slider Minimum="10"
                                Maximum="500"
                                Value="{Binding SpeedMs}"
                                Width="150"/>
                        <TextBlock Text="{Binding SpeedMs}"
                                   Width="40"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Content="Shuffle"
                            Height="36"
                            Margin="0,0,0,8"
                            Click="ShuffleButton_Click"/>

                    <Button Content="Start"
                            Height="36"
                            Margin="0,0,0,8"
                            Background="#2563EB"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="StartButton_Click"/>

                    <Button Content="Pause"
                            Height="36"
                            Margin="0,0,0,8"
                            Click="PauseButton_Click"/>

                    <Button Content="Step"
                            Height="36"
                            Margin="0,0,0,8"
                            Click="StepButton_Click"/>

                    <Button Content="Reset"
                            Height="36"
                            Click="ResetButton_Click"/>

                    <Separator Margin="0,20,0,12"/>

                    <TextBlock Text="Legend"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <StackPanel>
                        <TextBlock Text="⬤ 通常: グレー" Foreground="Gray"/>
                        <TextBlock Text="⬤ 比較中: オレンジ" Foreground="Orange"/>
                        <TextBlock Text="⬤ 交換中: 青" Foreground="DodgerBlue"/>
                        <TextBlock Text="⬤ Pivot: 紫" Foreground="MediumPurple"/>
                        <TextBlock Text="⬤ 確定済み: 緑" Foreground="MediumSeaGreen"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Visualization -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="18"
                    Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Array Visualization"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <Border Grid.Row="1"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="#FAFAFA"
                            Padding="8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Bars}"
                                          VerticalAlignment="Bottom">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Bottom"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="310"
                                              Width="{Binding BarWidth}"
                                              Margin="1,0"
                                              VerticalAlignment="Bottom">
                                            <Border Height="{Binding DisplayHeight}"
                                                    Background="{Binding Fill}"
                                                    CornerRadius="3,3,0,0"
                                                    VerticalAlignment="Bottom"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- Code Panel -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Pseudo Code"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding CodeLines}"
                             BorderThickness="0"
                             Background="#F9FAFB">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Background}"
                                        CornerRadius="4"
                                        Padding="6"
                                        Margin="0,2">
                                    <TextBlock FontFamily="Consolas"
                                               FontSize="14">
                                        <Run Text="{Binding LineNumber}"/>
                                        <Run Text=": "/>
                                        <Run Text="{Binding Text}"/>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="14"
                Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Message}"
                           FontSize="15"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center">
                    <Run Text="比較回数: "/>
                    <Run Text="{Binding CompareCount}"/>
                </TextBlock>

                <TextBlock Grid.Column="2"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center">
                    <Run Text="交換/配置回数: "/>
                    <Run Text="{Binding SwapCount}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>